generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum AppointmentStatus {
  SCHEDULED
  COMPLETED
  CANCELLED
}

model Appointment {
  id               String            @id @default(uuid())
  clientName       String
  aestheticianName String
  protocol         String
  dateTime         DateTime
  status           AppointmentStatus @default(SCHEDULED)
  createdAt        DateTime          @default(now())
}
